                    <i class="fa-solid fa-star text-yellow-400 text-sm"></i>
                    <span class="text-sm font-medium text-gray-600">Trusted by 10,000+ Parents</span>
                </div>
                <h1 class="font-serif text-5xl lg:text-7xl font-bold text-gray-800 leading-tight">
                    Everything for Your <span class="text-primary">Little One</span>
                </h1>
                <p class="text-lg text-gray-600 max-w-lg leading-relaxed">
                    Discover our curated collection of premium baby essentials, toys, and clothing. Safe, affordable, and absolutely adorable.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a href="#products" class="inline-flex items-center gap-2 bg-primary hover:bg-pink-600 text-white px-8 py-4 rounded-full font-semibold transition-all transform hover:scale-105 shadow-lg shadow-pink-200">
                        Shop Now
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                    <a href="#features" class="inline-flex items-center gap-2 bg-white hover:bg-gray-50 text-gray-800 px-8 py-4 rounded-full font-semibold transition-all border border-gray-200">
                        Learn More
                    </a>
                </div>
                <div class="flex items-center gap-4 pt-4">
                    <div class="flex -space-x-3">
                        <img src="https://i.pravatar.cc/150?img=1" alt="Customer" class="w-10 h-10 rounded-full border-2 border-white">
                        <img src="https://i.pravatar.cc/150?img=5" alt="Customer" class="w-10 h-10 rounded-full border-2 border-white">
                        <img src="https://i.pravatar.cc/150?img=8" alt="Customer" class="w-10 h-10 rounded-full border-2 border-white">
                    </div>
                    <div class="text-sm">
                        <div class="flex text-yellow-400">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <p class="text-gray-500">4.9/5 from 2,000+ reviews</p>
                    </div>
                </div>
            </div>
            <div class="relative lg:h-[600px] flex items-center justify-center">
                <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-secondary/20 rounded-full blur-3xl"></div>
                <img src="https://images.unsplash.com/photo-1515488042361-ee00e0ddd4e4?w=800&auto=format&fit=crop" alt="Happy baby with toys" class="relative rounded-3xl shadow-2xl w-full h-full object-cover animate-bounce-slow">
                <div class="absolute -bottom-6 -left-6 bg-white p-6 rounded-2xl shadow-xl">
                    <div class="flex items-center gap-3">
                        <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center text-green-600">
                            <i class="fa-solid fa-check text-xl"></i>
                        </div>
                        <div>
                            <p class="font-bold text-gray-800">Safe & Tested</p>
                            <p class="text-sm text-gray-500">Premium Quality</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
        <div class="max-w-7xl mx-auto">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <span class="text-primary font-semibold text-sm uppercase tracking-wider">Why Choose Us</span>
                <h2 class="font-serif text-4xl font-bold text-gray-800 mt-2 mb-4">Made with Love for Your Baby</h2>
                <p class="text-gray-600">We understand what parents need. That's why we provide only the best for your precious little ones.</p>
            </div>
            
            <div class="grid md:grid-cols-3 gap-8">
                <div class="group p-8 rounded-3xl bg-soft hover:bg-white hover:shadow-xl transition-all duration-300 border border-transparent hover:border-pink-100">
                    <div class="w-14 h-14 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-truck-fast text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-3">Fast Delivery</h3>
                    <p class="text-gray-600 leading-relaxed">Free shipping on orders over ₱999. Get your baby essentials delivered within 2-3 days.</p>
                </div>
                
                <div class="group p-8 rounded-3xl bg-soft hover:bg-white hover:shadow-xl transition-all duration-300 border border-transparent hover:border-pink-100">
                    <div class="w-14 h-14 bg-secondary/20 rounded-2xl flex items-center justify-center text-blue-500 mb-6 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-shield-check text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-3">Safety First</h3>
                    <p class="text-gray-600 leading-relaxed">All products are tested and certified safe for babies. Non-toxic materials only.</p>
                </div>
                
                <div class="group p-8 rounded-3xl bg-soft hover:bg-white hover:shadow-xl transition-all duration-300 border border-transparent hover:border-pink-100">
                    <div class="w-14 h-14 bg-pink-100 rounded-2xl flex items-center justify-center text-pink-500 mb-6 group-hover:scale-110 transition-transform">
                        <i class="fa-solid fa-heart text-2xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-3">Made with Love</h3>
                    <p class="text-gray-600 leading-relaxed">Each item is carefully selected with your baby's comfort and happiness in mind.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Products Section -->
    <section id="products" class="py-20 px-4 sm:px-6 lg:px-8 bg-cream">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
                <div>
                    <span class="text-primary font-semibold text-sm uppercase tracking-wider">Our Collection</span>
                    <h2 class="font-serif text-4xl font-bold text-gray-800 mt-2">Featured Products</h2>
                </div>
                <button onclick="showComingSoon()" class="text-primary font-semibold hover:text-pink-600 transition-colors flex items-center gap-2">
                    View All Products
                    <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>
            
            <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <!-- Product 1 -->
                <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100">
                    <div class="relative overflow-hidden aspect-square">
                        <img src="https://images.unsplash.com/photo-1560506840-ec148e82a604?w=600&auto=format&fit=crop" alt="Baby Crib" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        <div class="absolute top-4 left-4 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full">Bestseller</div>
                        <button onclick="addToCart(1, 'Premium Baby Crib', 4599.00, 'https://images.unsplash.com/photo-1560506840-ec148e82a604?w=600&auto=format&fit=crop')" class="absolute bottom-4 right-4 w-12 h-12 bg-white text-primary rounded-full shadow-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all hover:bg-primary hover:text-white">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>
                    <div class="p-6">
                        <div class="flex text-yellow-400 text-sm mb-2">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <h3 class="font-bold text-gray-800 mb-2">Premium Baby Crib</h3>
                        <div class="flex justify-between items-center">
                            <span class="text-primary font-bold text-lg">₱4,599</span>
                            <span class="text-gray-400 text-sm line-through">₱5,999</span>
                        </div>
                    </div>
                </div>

                <!-- Product 2 -->
                <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100">
                    <div class="relative overflow-hidden aspect-square">
                        <img src="https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?w=600&auto=format&fit=crop" alt="Stroller" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        <div class="absolute top-4 left-4 bg-secondary text-white text-xs font-bold px-3 py-1 rounded-full">New</div>
                        <button onclick="addToCart(2, 'Luxury Baby Stroller', 3299.00, 'https://images.unsplash.com/photo-1522771739844-6a9f6d5f14af?w=600&auto=format&fit=crop')" class="absolute bottom-4 right-4 w-12 h-12 bg-white text-primary rounded-full shadow-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all hover:bg-primary hover:text-white">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>
                    <div class="p-6">
                        <div class="flex text-yellow-400 text-sm mb-2">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star-half-stroke"></i>
                        </div>
                        <h3 class="font-bold text-gray-800 mb-2">Luxury Baby Stroller</h3>
                        <div class="flex justify-between items-center">
                            <span class="text-primary font-bold text-lg">₱3,299</span>
                        </div>
                    </div>
                </div>

                <!-- Product 3 -->
                <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100">
                    <div class="relative overflow-hidden aspect-square">
                        <img src="https://images.unsplash.com/photo-1544776193-352d25ca82cd?w=600&auto=format&fit=crop" alt="Toys Set" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        <button onclick="addToCart(3, 'Educational Toy Set', 899.00, 'https://images.unsplash.com/photo-1544776193-352d25ca82cd?w=600&auto=format&fit=crop')" class="absolute bottom-4 right-4 w-12 h-12 bg-white text-primary rounded-full shadow-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all hover:bg-primary hover:text-white">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>
                    <div class="p-6">
                        <div class="flex text-yellow-400 text-sm mb-2">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                        </div>
                        <h3 class="font-bold text-gray-800 mb-2">Educational Toy Set</h3>
                        <div class="flex justify-between items-center">
                            <span class="text-primary font-bold text-lg">₱899</span>
                            <span class="text-gray-400 text-sm line-through">₱1,299</span>
                        </div>
                    </div>
                </div>

                <!-- Product 4 -->
                <div class="group bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-gray-100">
                    <div class="relative overflow-hidden aspect-square">
                        <img src="https://images.unsplash.com/photo-1522771930-78848dc92939?w=600&auto=format&fit=crop" alt="Baby Clothes" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        <div class="absolute top-4 left-4 bg-green-500 text-white text-xs font-bold px-3 py-1 rounded-full">Sale</div>
                        <button onclick="addToCart(4, 'Organic Cotton Set', 649.00, 'https://images.unsplash.com/photo-1522771930-78848dc92939?w=600&auto=format&fit=crop')" class="absolute bottom-4 right-4 w-12 h-12 bg-white text-primary rounded-full shadow-lg flex items-center justify-center opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all hover:bg-primary hover:text-white">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>
                    <div class="p-6">
                        <div class="flex text-yellow-400 text-sm mb-2">
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-solid fa-star"></i>
                            <i class="fa-regular fa-star"></i>
                        </div>
                        <h3 class="font-bold text-gray-800 mb-2">Organic Cotton Set</h3>
                        <div class="flex justify-between items-center">
                            <span class="text-primary font-bold text-lg">₱649</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
