                    </div>
                </div>
                
                <div>
                    <h4 class="font-bold text-lg mb-6">Quick Links</h4>
                    <ul class="space-y-3 text-gray-400">
                        <li><a href="#home" class="hover:text-primary transition-colors flex items-center gap-2"><i class="fa-solid fa-chevron-right text-xs"></i> Home</a></li>
                        <li><a href="#products" class="hover:text-primary transition-colors flex items-center gap-2"><i class="fa-solid fa-chevron-right text-xs"></i> Shop</a></li>
                        <li><a href="#features" class="hover:text-primary transition-colors flex items-center gap-2"><i class="fa-solid fa-chevron-right text-xs"></i> About Us</a></li>
                        <li><a href="#" onclick="showComingSoon()" class="hover:text-primary transition-colors flex items-center gap-2"><i class="fa-solid fa-chevron-right text-xs"></i> Contact</a></li>
                    </ul>
