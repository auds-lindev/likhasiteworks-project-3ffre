        <div class="max-w-7xl mx-auto">
            <div class="bg-gradient-to-r from-primary/5 to-secondary/5 rounded-3xl p-8 md:p-16 text-center">
                <h2 class="font-serif text-3xl md:text-4xl font-bold text-gray-800 mb-4">Have Questions?</h2>
                <p class="text-gray-600 mb-8 max-w-2xl mx-auto">We're here to help! Reach out to our friendly customer service team for any inquiries about our products.</p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="mailto:hello@beibico.com" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-pink-600 text-white px-8 py-4 rounded-full font-semibold transition-all">
                        <i class="fa-solid fa-envelope"></i>
                        Email Us
                    </a>
                    <a href="tel:+631234567890" class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-800 px-8 py-4 rounded-full font-semibold transition-all border border-gray-200">
                        <i class="fa-solid fa-phone"></i>
                        Call Us
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-16 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
            <div class="grid md:grid-cols-4 gap-12 mb-12">
                <div class="md:col-span-2">
                    <div class="flex items-center gap-2 mb-6">
                        <div class="w-10 h-10 bg-primary rounded-full flex items-center justify-center">
                            <i class="fa-solid fa-baby text-white text-xl"></i>
                        </div>
                        <span class="font-serif text-2xl font-bold">Beibico</span>
                    </div>
                    <p class="text-gray-400 mb-6 max-w-sm">Quality baby and kids products made with love. We're dedicated to providing safe, affordable, and adorable items for your little ones.</p>
                    <div class="flex gap-4">
                        <a href="#" onclick="showComingSoon()" class="w-10 h-10 bg-gray-800 hover:bg-primary rounded-full flex items-center justify-center transition-colors">
                            <i class="fa-brands fa-facebook-f"></i>
                        </a>
                        <a href="#" onclick="showComingSoon()" class="w-10 h-10 bg-gray-800 hover:bg-primary rounded-full flex items-center justify-center transition-colors">
                            <i class="fa-brands fa-instagram"></i>
                        </a>
                        <a href="#" onclick="showComingSoon()" class="w-10 h-10 bg-gray-800 hover:bg-primary rounded-full flex items-center justify-center transition-colors">
                            <i class="fa-brands fa-twitter"></i>
